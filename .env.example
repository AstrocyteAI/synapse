# Copy to .env — do not commit .env

# --- Astrocyte gateway ---
ASTROCYTE_TOKEN=dev-astrocyte-api-key

# --- Centrifugo ---
CENTRIFUGO_API_KEY=dev-centrifugo-api-key
CENTRIFUGO_TOKEN_SECRET=dev-centrifugo-token-secret

# --- Synapse auth ---
# dev mode: jwt_hs256 (shared secret) | production: jwt_oidc (JWKS/RS256)
SYNAPSE_AUTH_MODE=jwt_hs256
SYNAPSE_JWT_SECRET=dev-jwt-secret-change-in-production
SYNAPSE_JWT_AUDIENCE=synapse
# For jwt_oidc mode:
# SYNAPSE_AUTH_MODE=jwt_oidc
# SYNAPSE_JWT_JWKS_URL=https://your-oidc-provider/.well-known/jwks.json
# SYNAPSE_JWT_ISSUER=https://your-oidc-provider
# SYNAPSE_JWT_AUDIENCE=synapse

# --- LLM ---
SYNAPSE_LLM_PROVIDER=litellm
# LiteLLM proxy (optional — omit to use litellm library directly)
# LITELLM_API_BASE=http://localhost:4000
# LITELLM_API_KEY=sk-your-litellm-key

# --- EE license (optional) ---
# SYNAPSE_LICENSE_KEY=
