#!/usr/bin/env bash
# Pre-commit: ruff lint + format check for the Python backend.
# Install once with: git config core.hooksPath .githooks

set -euo pipefail

BACKEND="apps/backend"

# Only run if there are staged Python files in the backend.
staged=$(git diff --cached --name-only --diff-filter=ACM | grep "^${BACKEND}/.*\.py$" || true)
if [ -z "$staged" ]; then
    exit 0
fi

cd "$BACKEND"
echo "→ ruff check..."
uv run --with ruff ruff check synapse tests
echo "→ ruff format --check..."
uv run --with ruff ruff format --check synapse tests
